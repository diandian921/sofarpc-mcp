{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://sofarpc.local/protocol/invoke.response.schema.json",
  "title": "InvokeResponseData",
  "type": "object",
  "required": ["result", "elapsedMs"],
  "properties": {
    "result": {
      "description": "Flattened RPC response (any JSON type). Null if the call did not produce a result."
    },
    "elapsedMs": {
      "type": "integer",
      "minimum": 0,
      "description": "Wall-clock time spent on the direct RPC call itself."
    },
    "assertions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "passed"],
        "properties": {
          "path": {"type": "string"},
          "passed": {"type": "boolean"},
          "expected": {},
          "actual": {},
          "message": {"type": "string"}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
