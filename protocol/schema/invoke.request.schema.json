{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://sofarpc.local/protocol/invoke.request.schema.json",
  "title": "InvokePayload",
  "type": "object",
  "required": ["address", "service", "method", "argTypes", "args"],
  "properties": {
    "address": {
      "type": "string",
      "minLength": 1,
      "description": "Target SofaRPC bolt address, e.g. 10.74.194.40:12200"
    },
    "service": {
      "type": "string",
      "minLength": 1,
      "description": "Fully qualified service interface name"
    },
    "method": {
      "type": "string",
      "minLength": 1
    },
    "argTypes": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Fully qualified argument class names, same length as args"
    },
    "args": {
      "type": "array",
      "description": "Argument values. Each element is a JSON-serializable object matching the corresponding argType."
    },
    "assertions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path"],
        "properties": {
          "path": {
            "type": "string",
            "description": "JSONPath expression evaluated against flattened response"
          },
          "equals": {
            "description": "Expected value (any JSON type)"
          },
          "exists": {
            "type": "boolean",
            "description": "If true, assertion passes when path resolves to a non-null value"
          }
        },
        "additionalProperties": false
      }
    },
    "rpcTimeoutMs": {
      "type": "integer",
      "minimum": 1,
      "description": "Per-call timeout in milliseconds."
    },
    "rawResult": {
      "type": "boolean",
      "description": "Include the decoded Java object shape in invoke response data when true."
    }
  },
  "additionalProperties": false
}
