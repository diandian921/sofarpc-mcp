{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://sofarpc.local/protocol/envelope.response.schema.json",
  "title": "ResponseEnvelope",
  "type": "object",
  "required": ["requestId", "ok", "code"],
  "properties": {
    "requestId": {
      "type": "string",
      "minLength": 1,
      "description": "Echoed from the request."
    },
    "ok": {
      "type": "boolean"
    },
    "code": {
      "type": "string",
      "enum": [
        "SUCCESS",
        "BAD_REQUEST",
        "CONNECT_FAILED",
        "RPC_TIMEOUT",
        "INVOKE_FAILED",
        "ASSERTION_FAILED",
        "DAEMON_UNAVAILABLE",
        "INTERNAL_ERROR"
      ]
    },
    "data": {
      "description": "Op-specific success data. See <op>.response.schema.json. Null on failure."
    },
    "error": {
      "oneOf": [
        {"type": "null"},
        {
          "type": "object",
          "required": ["message"],
          "properties": {
            "message": {"type": "string"},
            "cause": {"type": "string"},
            "details": {"type": "object", "additionalProperties": true}
          },
          "additionalProperties": false
        }
      ]
    },
    "meta": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
